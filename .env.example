# ============================================================
# Gumroad AI Workspace — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ------ Optional Gumroad CLI credential for non-interactive CI ------
# Local agents should normally run: gumroad auth login
GUMROAD_ACCESS_TOKEN=

# ------ Admin token (only for gumroad admin commands) ------
# GUMROAD_ADMIN_TOKEN=

# ------ AI Subscription Costs (EUR — used by agent survival logic) ------
# Monthly cost of Antigravity CLI
ANTIGRAVITY_MONTHLY_COST_EUR=20
# Monthly cost of Claude Code
CLAUDE_CODE_MONTHLY_COST_EUR=18
# Monthly cost of Codex CLI
CODEX_MONTHLY_COST_EUR=20
# Total monthly target the agents must hit
AGENT_MONTHLY_TARGET_EUR=60

# ------ Social Media Bots ------
# Bluesky
BLUESKY_USERNAME=
BLUESKY_PASSWORD=

# Mastodon
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# Pinterest
# Create/confirm redirect URI in the Pinterest app settings, then run:
# scripts/pinterest login
# scripts/pinterest exchange "<code>"
# Production publishing is manual review first:
# scripts/pinterest draft
# scripts/pinterest publish agent/pinterest_queue/<draft>.json
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_API_BASE=https://api.pinterest.com/v5
# For Trial-access sandbox tests, use:
# PINTEREST_API_BASE=https://api-sandbox.pinterest.com/v5
PINTEREST_REDIRECT_URI=http://localhost:3003/pinterest/callback
PINTEREST_SCOPES=user_accounts:read,boards:read,boards:write,pins:read,pins:write
PINTEREST_ACCESS_TOKEN=
PINTEREST_REFRESH_TOKEN=
PINTEREST_BOARD_NAME=AI Tools & Digital Templates
# Optional: set after creating/finding a board to avoid lookup/create calls.
PINTEREST_BOARD_ID=

# Optional sandbox test settings. Do not reuse production access tokens here.
PINTEREST_SANDBOX_API_BASE=https://api-sandbox.pinterest.com/v5
PINTEREST_SANDBOX_ACCESS_TOKEN=
PINTEREST_SANDBOX_BOARD_NAME=AI Tools Sandbox
PINTEREST_SANDBOX_BOARD_ID=
