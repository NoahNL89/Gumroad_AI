# ============================================================
# Gumroad CLI — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Your Gumroad seller API token
# Get it at: https://app.gumroad.com/settings/advanced
GUMROAD_ACCESS_TOKEN=

# Admin token (only needed for gumroad admin commands)
# GUMROAD_ADMIN_TOKEN=

# Override admin API base URL (local development only)
# GUMROAD_ADMIN_API_BASE_URL=
